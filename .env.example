# ============================================================
# IDEP-Gestor — Variaveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
# ============================================================

# ============================================================
# SUPABASE — Banco de Dados & Autenticacao
# ============================================================
# Substitua pelos valores do seu projeto Supabase (local ou remoto)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui
# SUPABASE_SERVICE_KEY=deixe-comentado-em-producao

# ============================================================
# DEEPSEEK — Inteligencia Artificial (modelo padrao)
# ============================================================
VITE_DEEPSEEK_API_KEY=

# ============================================================
# OPENAI — Inteligencia Artificial (modelo alternativo)
# ============================================================
VITE_OPENAI_API_KEY=

# ============================================================
# SMTP — Envio de E-mails (via Supabase, opcional)
# ============================================================
# SUPABASE_SMTP_HOST=
# SUPABASE_SMTP_PORT=
# SUPABASE_SMTP_USER=
# SUPABASE_SMTP_PASS=

# ============================================================
# SUPABASE CLI — Configuracao Local (opcional)
# ============================================================
# OPENAI_API_KEY=
# SENDGRID_API_KEY=
